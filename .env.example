# SpringAdmin environment (dev) — dimuat via `spring.config.import: optional:file:.env`
# (lihat application.yml). Scaffold xpose menulis APP_PORT + DB_* ke file .env.

APP_PORT=8006

# Database — default dev: sqlite (file dibuat otomatis, tanpa server, sesi in-memory).
# DB_TYPE menentukan profil Spring: sqlite → application-sqlite.yml; mysql/mariadb →
# konfigurasi dasar MySQL. postgres TIDAK didukung (driver tidak dibundel).
DB_TYPE=sqlite
# DB_DATABASE=./springadmin.db

# Untuk MySQL/MariaDB, isi bagian ini (atau full DB_URL yang menang atas parts):
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=springadmin
# DB_URL=jdbc:mysql://127.0.0.1:3306/springadmin?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# CATATAN: bila hanya DB_URL yang di-set (tanpa DB_TYPE), set juga SPRING_PROFILES_ACTIVE=default.

# Redis — hanya dipakai profil non-sqlite (sesi Redis-backed).
# REDIS_URL=redis://127.0.0.1:6379

# SESSION_TTL_HOURS=6
# SESSION_COOKIE_SECURE=false
